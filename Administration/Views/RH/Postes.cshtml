@model List<Administration.Models.OffreEmploi>
@{
    ViewData["Title"] = "Liste des postes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-semibold">Postes disponibles</h5>
        <a asp-action="CreatePoste" class="btn btn-primary btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nouveau poste
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-3 opacity-50">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <p>Aucun poste trouvé.</p>
                    <a asp-action="CreatePoste" class="btn btn-primary btn-sm">Créer le premier poste</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Titre</th>
                                <th>Département</th>
                                <th>Type</th>
                                <th>Expérience</th>
                                <th>Niveau Éducation</th>
                                <th>Statut</th>
                                <th>Date création</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model)
                            {
                                <tr>
                                    <td><strong>@o.Titre</strong></td>
                                    <td>@o.Departement</td>
                                    <td>@o.Type</td>
                                    <td>@o.Experience an(s)</td>
                                    <td>@o.NiveauEducation</td>
                                    <td>
                                        <span class="badge @(o.Statut == "ACTIF" ? "bg-success" : "bg-secondary")">
                                            @o.Statut
                                        </span>
                                    </td>
                                    <td>@o.DateCreation.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">
                                        <a asp-action="ResultatsCV" asp-route-offreId="@o.Id"
                                           class="btn btn-sm btn-outline-success" title="Décisions CV">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="20 6 9 17 4 12"/>
                                            </svg>
                                        </a>
                                        <a asp-action="EditPoste" asp-route-id="@o.Id"
                                           class="btn btn-sm btn-outline-primary" title="Modifier">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                        </a>
                                        <form asp-action="DeletePoste" asp-route-id="@o.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Supprimer ce poste ?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"/>
                                                    <path d="M19 6l-1 14H6L5 6"/>
                                                    <path d="M10 11v6"/><path d="M14 11v6"/>
                                                    <path d="M9 6V4h6v2"/>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
