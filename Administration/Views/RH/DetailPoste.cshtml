                        var color = avatarColors[colorIndex];
                        var initial = candidat.NomUtilisateur?.Length > 0 ? candidat.NomUtilisateur[0].ToString().ToUpper() : "?";
                        
                        var isActive = candidat.IsActive;
                        var statusClass = isActive ? "status-active" : "status-inactive";
                        
                        var score2 = scoreByUserId.TryGetValue(candidat.Id, out var s2) ? s2 : 0;
                        var scoreClass2 = score2 >= 80 ? "high" : (score2 >= 70 ? "medium" : "low");
