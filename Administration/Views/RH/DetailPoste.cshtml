@section Scripts {
    <script>
        function searchCandidates() {
            const input = document.getElementById('candidateSearch');
            const filter = input.value.toLowerCase();
            const table = document.getElementById('candidatesTable');
            if (!table) return;
            
            const tr = table.getElementsByTagName('tr');
            for (let i = 1; i < tr.length; i++) {
                const tdName = tr[i].getElementsByTagName('td')[0];
                const tdEmail = tr[i].getElementsByTagName('td')[1];
                if (tdName || tdEmail) {
                    const nameValue = (tdName?.textContent || tdName?.innerText || '').toLowerCase();
                    const emailValue = (tdEmail?.textContent || tdEmail?.innerText || '').toLowerCase();
                    
                    if (nameValue.indexOf(filter) > -1 || emailValue.indexOf(filter) > -1) {
                        tr[i].style.display = '';
                    } else {
                        tr[i].style.display = 'none';
                    }
                }
            }
        }

        // Search for second table (Candidats ayant postulé)
        function searchCandidates2() {
