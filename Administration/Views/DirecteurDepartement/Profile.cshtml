@model Administration.ViewModels.ProfileEditViewModel
@{
    ViewData["Title"] = "Mon Profil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <!-- Info card -->
            <div class="card shadow-sm mb-4 border-0" style="background: linear-gradient(135deg,#f59e0b,#ef4444); color:white;">
                <div class="card-body d-flex align-items-center gap-4 py-4">
                    <div class="rounded-circle bg-white d-flex align-items-center justify-content-center fw-bold text-warning"
                         style="width:64px;height:64px;font-size:1.5rem;">
                        @(Model.NomUtilisateur.Length >= 2 ? Model.NomUtilisateur[..2].ToUpper() : Model.NomUtilisateur.ToUpper())
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">@Model.NomUtilisateur</h5>
                        <small class="opacity-75">Directeur de Département</small>
                    </div>
                </div>
            </div>

            <!-- Edit form -->
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-semibold">Modifier mon profil</div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="NomUtilisateur" class="form-label fw-semibold">Nom d'utilisateur</label>
                            <input asp-for="NomUtilisateur" class="form-control bg-light" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label fw-semibold">
                                Nouveau mot de passe
                                <small class="text-muted fw-normal">(laisser vide pour ne pas changer)</small>
                            </label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="Nouveau mot de passe" />
                        </div>

                        <button type="submit" class="btn btn-primary">Mettre à jour</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
