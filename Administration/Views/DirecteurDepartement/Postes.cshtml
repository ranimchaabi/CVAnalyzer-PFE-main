@model List<Administration.Models.OffreEmploi>
@{
    ViewData["Title"] = "Liste des postes";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var search = ViewBag.Search as string ?? "";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-semibold">Postes disponibles</h5>
    </div>

    <!-- Recherche -->
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="search" value="@search" class="form-control form-control-sm" placeholder="Rechercher par titre ou département...">
                <button type="submit" class="btn btn-sm btn-outline-primary">Rechercher</button>
                @if (!string.IsNullOrEmpty(search))
                {
                    <a asp-action="Postes" class="btn btn-sm btn-outline-secondary">Réinitialiser</a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-3 opacity-50">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <p>Aucun poste trouvé.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Titre</th>
                                <th>Département</th>
                                <th>Type</th>
                                <th>Expérience</th>
                                <th>Niveau Éducation</th>
                                <th>Statut</th>
                                <th>Date création</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-action="DetailsPoste" asp-route-id="@o.Id" class="text-decoration-none fw-semibold">
                                            @o.Titre
                                        </a>
                                    </td>
                                    <td>@o.Departement</td>
                                    <td>@o.Type</td>
                                    <td>@o.Experience an(s)</td>
                                    <td>@o.NiveauEducation</td>
                                    <td>
                                        <span class="badge @(o.Statut == "ACTIF" ? "bg-success" : "bg-secondary")">
                                            @o.Statut
                                        </span>
                                    </td>
                                    <td>@o.DateCreation.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">
                                        <a asp-action="ResultatsCV" asp-route-offreId="@o.Id" class="btn btn-sm btn-outline-info" title="Tous les CV">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                            </svg>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>