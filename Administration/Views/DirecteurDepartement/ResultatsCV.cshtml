@model List<Administration.Models.Match>

@{
    ViewData["Title"] = "Résultats CV & Décisions";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var offres = ViewBag.Offres as List<Administration.Models.OffreEmploi> ?? new();
    int? selectedId = ViewBag.SelectedOffreId;

    var offreSelectionnee = selectedId.HasValue
        ? offres.FirstOrDefault(o => o.Id == selectedId.Value)
        : null;
}

<div class="container-fluid px-4 py-3">

    <!-- FILTRE -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get">
                <label class="form-label">Sélectionner un poste</label>
                <select name="offreId" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Choisir --</option>
                    @foreach (var o in offres)
                    {
                        <option value="@o.Id" selected="@(selectedId == o.Id)">
                            @o.Titre — @o.Departement
                        </option>
                    }
                </select>
            </form>
        </div>
    </div>

    @if (selectedId.HasValue && offreSelectionnee != null)
    {
        <!-- DÉTAILS DU POSTE -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">
                Détails du poste : @offreSelectionnee.Titre
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Département</dt>
                            <dd class="col-sm-8">@offreSelectionnee.Departement</dd>

                            <dt class="col-sm-4">Type</dt>
                            <dd class="col-sm-8">@offreSelectionnee.Type</dd>

                            <dt class="col-sm-4">Expérience requise</dt>
                            <dd class="col-sm-8">@offreSelectionnee.Experience an(s)</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Niveau d'éducation</dt>
                            <dd class="col-sm-8">@offreSelectionnee.NiveauEducation</dd>

                            <dt class="col-sm-4">Statut</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(offreSelectionnee.Statut == "ACTIF" ? "bg-success" : "bg-secondary")">
                                    @offreSelectionnee.Statut
                                </span>
                            </dd>

                            <dt class="col-sm-4">Date de création</dt>
                            <dd class="col-sm-8">@offreSelectionnee.DateCreation.ToString("dd/MM/yyyy")</dd>
                        </dl>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(offreSelectionnee.Description))
                {
                    <div class="mt-3">
                        <strong>Description :</strong>
                        <p class="mt-1">@offreSelectionnee.Description</p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- RÉSULTATS DES CANDIDATS -->
    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>Candidats pour @offreSelectionnee?.Titre</strong>
                <span class="badge bg-secondary ms-2">@Model.Count candidat(s)</span>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Candidat</th>
                                <th>Email</th>
                                <th>Téléphone</th>
                                <th>Compétences</th>
                                <th>Diplôme</th>
                                <th>Expérience</th>
                                <th>Score Global</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rank = 1;
                            }
                            @foreach (var m in Model)
                            {
                                <tr>
                                    <td><strong>@rank</strong></td>
                                    <td>@(m.Cv?.DonneesCv?.NomCandidat ?? "—")</td>
                                    <td>@(m.Cv?.DonneesCv?.Email ?? "—")</td>
                                    <td>@(m.Cv?.DonneesCv?.Telephone ?? "—")</td>
                                    <td>
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-info" style="width:@m.CompetenceScore%"></div>
                                        </div>
                                        <small>@m.CompetenceScore.ToString("0")%</small>
                                    </td>
                                    <td>
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-warning" style="width:@m.DiplomeScore%"></div>
                                        </div>
                                        <small>@m.DiplomeScore.ToString("0")%</small>
                                    </td>
                                    <td>
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-success" style="width:@m.ExperienceScore%"></div>
                                        </div>
                                        <small>@m.ExperienceScore.ToString("0")%</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-dark">
                                            @m.GlobalScore.ToString("0.0")%
                                        </span>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (selectedId.HasValue)
    {
        <div class="alert alert-info">
            Aucun CV trouvé pour ce poste.
        </div>
    }
    else
    {
        <div class="text-center text-muted py-5">
            Sélectionnez un poste pour afficher les résultats.
        </div>
    }

</div>