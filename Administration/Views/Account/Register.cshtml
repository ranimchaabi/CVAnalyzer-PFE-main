@model Administration.ViewModels.RegisterViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Sign Up";
}

<div class="card p-4">
    <h2 class="text-center mb-2">Sign Up</h2>
    <p class="text-center text-muted">Create your account</p>

    <form method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Username -->
        <div class="mb-3">
            <label class="form-label">Nom Utilisateur</label>
            <input asp-for="NomUtilisateur" class="form-control" placeholder="Nom utilisateur">
            <span asp-validation-for="NomUtilisateur" class="text-danger small"></span>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="Email">
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <!-- Password -->
        <div class="mb-3">
            <label class="form-label">Mot de passe</label>
            <input asp-for="MotPasse" type="password" class="form-control" placeholder="Mot de passe">
            <span asp-validation-for="MotPasse" class="text-danger small"></span>
        </div>

        <!-- Confirm Password -->
        <div class="mb-3">
            <label class="form-label">Confirmer mot de passe</label>
            <input asp-for="ConfirmMotPasse" type="password" class="form-control" placeholder="Confirmer">
            <span asp-validation-for="ConfirmMotPasse" class="text-danger small"></span>
        </div>

        <!-- Role -->
        <div class="mb-3">
            <label class="form-label">Role</label>
            <select asp-for="Role" class="form-control">
                <option value="">-- Choisir --</option>
                <option value="Candidat">Candidat</option>
                <option value="RH">RH</option>
                <option value="Directeur">Directeur</option>
                <option value="Admin">Admin</option>
            </select>
        </div>

        <!-- Button -->
        <button type="submit" class="btn btn-success w-100">Sign Up</button>

        <!-- Link -->
        <div class="mt-3 text-center">
            Already have an account? <a asp-action="Login">Sign In</a>
        </div>

    </form>
</div>