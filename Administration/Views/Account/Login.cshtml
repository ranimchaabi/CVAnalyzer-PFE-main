@model LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Sign In";
}

<div class="card p-4">
    <h2 class="text-center mb-2">Sign In</h2>
    <p class="text-center text-muted">Welcome back!</p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Nom Utilisateur</label>
            <input asp-for="NomUtilisateur" class="form-control" placeholder="Nom utilisateur">
            <span asp-validation-for="NomUtilisateur" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Mot de passe</label>
            <input asp-for="MotPasse" type="password" class="form-control" placeholder="Mot de passe">
            <span asp-validation-for="MotPasse" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Sign In</button>

        <div class="mt-3 text-center">
            Don't have an account? <a asp-action="Register">Sign Up</a>
        </div>
    </form>
</div>