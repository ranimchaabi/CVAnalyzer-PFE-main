                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-action-sm btn-delete" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Section Candidats -->
        @if (candidats.Any())
        {
            <div class="section-card" data-role="candidat">
                <div class="section-header">
                    <h5 class="section-title candidat">
                        <i class="bi bi-person-fill"></i>Candidats
                    </h5>
                    <span class="user-count" id="count-candidat">@candidats.Count utilisateur(s)</span>
                </div>
                <div class="table-responsive">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th>Utilisateur</th>
                                <th>Email</th>
                                <th>Statut</th>
                                <th>Date de création</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in candidats)
                            {
                                var photoUrl = GetProfileImageUrl(u);
                                <tr class="user-row" data-name="@u.NomUtilisateur.ToLower()" data-email="@u.Email.ToLower()" data-role="candidat" data-departements="@(u.Departements?.ToLower() ?? "")">
                                    <td>
                                        <div class="user-info">
