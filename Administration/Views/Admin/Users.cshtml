@model List<Administration.Models.Utilisateur>
@{
    ViewData["Title"] = "Gestion des utilisateurs";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var search = ViewBag.Search as string ?? "";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-semibold">Utilisateurs</h5>
        <a asp-action="CreateUser" class="btn btn-primary btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nouvel utilisateur
        </a>
    </div>

    <!-- Barre de recherche -->
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="search" value="@search" class="form-control form-control-sm" placeholder="Rechercher par nom, email ou rôle...">
                <button type="submit" class="btn btn-sm btn-outline-primary">Rechercher</button>
                @if (!string.IsNullOrEmpty(search))
                {
                    <a asp-action="Users" class="btn btn-sm btn-outline-secondary">Réinitialiser</a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">Aucun utilisateur trouvé.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Nom d'utilisateur</th>
                                <th>Email</th>
                                <th>Rôle</th>
                                <th>Actif</th>
                                <th>Date création</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                <tr>
                                    <td>@u.NomUtilisateur</td>
                                    <td>@u.Email</td>
                                    <td>@u.Role</td>
                                    <td>
                                        @if (u.IsActive)
                                        {
                                            <span class="badge bg-success">Actif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactif</span>
                                        }
                                    </td>
                                    <td>@u.DateCreation.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">
                                        <a asp-action="UserDetails" asp-route-id="@u.Id" class="btn btn-sm btn-outline-info" title="Détails">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                            </svg>
                                        </a>
                                        <a asp-action="EditUser" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary" title="Modifier">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                        </a>
                                        <form asp-action="ToggleActive" asp-route-id="@u.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(u.IsActive ? "Désactiver" : "Activer")">
                                                @if (u.IsActive)
                                                {
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                                                    </svg>
                                                }
                                                else
                                                {
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
                                                    </svg>
                                                }
                                            </button>
                                        </form>
                                        <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Supprimer définitivement cet utilisateur ?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
                                                    <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>