                                    <td class="text-end">
                                        <a asp-action="UserDetails" asp-route-id="@u.Id" class="btn-action-sm btn-view" title="Détails">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        
                                        <form asp-action="ToggleActive" asp-route-id="@u.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-action-sm @(u.IsActive ? "btn-toggle-active" : "btn-toggle-inactive")" title="@(u.IsActive ? "Désactiver" : "Activer")">
                                                <i class="bi @(u.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                            </button>
                                        </form>
                                        <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-action-sm btn-delete" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    <!-- No Results Message -->
    <div id="noResults" class="no-results hidden-section">
        <i class="bi bi-search"></i>
        <h6>Aucun utilisateur trouvé</h6>
        <p>Aucun utilisateur ne correspond à votre recherche.</p>
    </div>
</div>

@section Scripts {
    <script>
        // Live Search and Filter Functionality
        const searchInput = document.getElementById('liveSearch');
        const clearButton = document.getElementById('clearSearch');
        const searchStats = document.getElementById('searchStats');
        const noResults = document.getElementById('noResults');
        const userRows = document.querySelectorAll('.user-row');
        const sectionCards = document.querySelectorAll('.section-card');
        const roleFilter = document.getElementById('roleFilter');
        const departementFilter = document.getElementById('departementFilter');
        const departementFilterContainer = document.getElementById('departementFilterContainer');
        

        let totalUsers = userRows.length;

        // Show/hide department filter based on role selection
        roleFilter.addEventListener('change', function() {
            if (this.value === 'Directeur') {
                departementFilterContainer.style.display = 'block';
            } else {
                departementFilterContainer.style.display = 'none';
                if (departementFilter) departementFilter.value = '';
            }
            performSearch();
        });

        // Department filter change
        if (departementFilter) {
            departementFilter.addEventListener('change', performSearch);
        }

        // Search function
        function performSearch() {
            const query = searchInput.value.toLowerCase().trim();
            const selectedRole = roleFilter.value;
            const selectedDepartement = departementFilter ? departementFilter.value : '';
            let visibleCount = 0;

            // Show/hide clear button
            clearButton.classList.toggle('visible', query.length > 0);

            // Filter rows
            userRows.forEach(row => {
                const name = row.getAttribute('data-name');
                const email = row.getAttribute('data-email');
                const role = row.getAttribute('data-role');
                const departements = row.getAttribute('data-departements') || '';
                const nameElement = row.querySelector('.user-name');
                const emailElement = row.querySelector('.user-email');

                let matchesSearch = !query || name.includes(query) || email.includes(query);
                let matchesRole = !selectedRole || role.toLowerCase() === selectedRole.toLowerCase();
                let matchesDepartement = !selectedDepartement || (role.toLowerCase() === 'directeur' && departements.includes(selectedDepartement.toLowerCase()));

                if (matchesSearch && matchesRole && matchesDepartement) {
                    row.classList.remove('hidden-row');
                    visibleCount++;
                    
                    // Highlight matching text
                    if (query && nameElement) {
                        nameElement.innerHTML = highlightText(nameElement.textContent, query);
                    } else if (nameElement) {
                        nameElement.textContent = nameElement.textContent;
                    }
                    if (query && emailElement) {
                        emailElement.innerHTML = highlightText(emailElement.textContent, query);
                    } else if (emailElement) {
                        emailElement.textContent = emailElement.textContent;
                    }
                } else {
                    row.classList.add('hidden-row');
                    restoreOriginalText(row);
                }
            });

            // Update section visibility and counts
            sectionCards.forEach(card => {
                const visibleRows = card.querySelectorAll('.user-row:not(.hidden-row)');
                const cardRole = card.getAttribute('data-role');
                const countElement = document.getElementById('count-' + cardRole);
                
                if (visibleRows.length === 0) {
                    card.classList.add('hidden-section');
                } else {
                    card.classList.remove('hidden-section');
                    if (countElement) {
                        countElement.textContent = visibleRows.length + ' utilisateur' + (visibleRows.length > 1 ? 's' : '');
                    }
                }
            });

            // Update stats
            if (query || selectedRole || selectedDepartement) {
                searchStats.textContent = visibleCount + ' résultat' + (visibleCount > 1 ? 's' : '') + ' sur ' + totalUsers;
            } else {
                searchStats.textContent = '';
            }

            // Show no results message
            if (visibleCount === 0) {
                noResults.classList.remove('hidden-section');
            } else {
                noResults.classList.add('hidden-section');
            }
        }

        // Highlight matching text
        function highlightText(text, query) {
            if (!query) return text;
            const regex = new RegExp('(' + escapeRegex(query) + ')', 'gi');
            return text.replace(regex, '<span class="highlight">$1</span>');
        }

        // Escape special regex characters
        function escapeRegex(string) {
            return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }

        // Restore original text (remove highlights)
        function restoreOriginalText(row) {
            const nameElement = row.querySelector('.user-name');
            const emailElement = row.querySelector('.user-email');
            
            if (nameElement) {
                nameElement.textContent = nameElement.textContent;
            }
            if (emailElement) {
                emailElement.textContent = emailElement.textContent;
            }
        }

        // Update original counts
        function updateCounts() {
            sectionCards.forEach(card => {
                const role = card.getAttribute('data-role');
                const countElement = document.getElementById('count-' + role);
                const allRows = card.querySelectorAll('.user-row');
                
                if (countElement) {
                    countElement.textContent = allRows.length + ' utilisateur' + (allRows.length > 1 ? 's' : '');
                }
            });
        }

        // Event listeners
        searchInput.addEventListener('input', performSearch);

        clearButton.addEventListener('click', () => {
            searchInput.value = '';
            performSearch();
            searchInput.focus();
        });

        // Initialize
        searchInput.focus();
    </script>
}