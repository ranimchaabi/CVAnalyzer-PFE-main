@model Administration.Models.Match
@{
    ViewData["Title"] = "Analyse du candidat";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-semibold">Résultat du matching</h5>
        <a asp-action="DetailsPoste" asp-route-id="@Model.OffreId" class="btn btn-outline-secondary btn-sm">
            ← Retour au poste
        </a>
    </div>

    <div class="row">
        <!-- Informations candidat -->
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-semibold">Candidat</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Nom complet</dt>
                        <dd class="col-sm-8">@(Model.Cv.DonneesCv?.NomCandidat ?? "—")</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(Model.Cv.DonneesCv?.Email ?? "—")</dd>

                        <dt class="col-sm-4">Téléphone</dt>
                        <dd class="col-sm-8">@(Model.Cv.DonneesCv?.Telephone ?? "—")</dd>

                        <dt class="col-sm-4">CV déposé le</dt>
                        <dd class="col-sm-8">@Model.Cv.UploadDate.ToString("dd/MM/yyyy")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Score global -->
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-semibold">Score global</div>
                <div class="card-body text-center">
                    <div class="display-1 fw-bold text-primary">@Model.GlobalScore.ToString("F2")%</div>
                    <p class="text-muted mt-2">Correspondance avec le poste</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Détails des scores par critère -->
    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">Détail des critères</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Critère</th>
                            <th>Score</th>
                            <th>Poids</th>
                            <th>Commentaire</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Compétences</td>
                            <td>@Model.CompetenceScore.ToString("F2")%</td>
                            <td>40%</td>
                            <td>Correspondance des compétences requises</td>
                        </tr>
                        <tr>
                            <td>Diplôme / Éducation</td>
                            <td>@Model.DiplomeScore.ToString("F2")%</td>
                            <td>30%</td>
                            <td>Niveau d'étude vs exigences</td>
                        </tr>
                        <tr>
                            <td>Expérience</td>
                            <td>@Model.ExperienceScore.ToString("F2")%</td>
                            <td>30%</td>
                            <td>Années d'expérience vs requis</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="mt-3 text-end">
        <a asp-action="ResultatsCV" asp-route-offreId="@Model.OffreId" class="btn btn-secondary">
            Voir tous les candidats
        </a>
    </div>
</div>