@model Administration.ViewModels.DashboardStatsViewModel
@{
    ViewData["Title"] = "Tableau de bord";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h3 class="fw-bold">Dashboard</h3>
        <p class="text-muted">Overview of your platform statistics</p>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <!-- USERS -->
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Utilisateurs</h6>
                        <h2 class="fw-bold">@Model.TotalUsers</h2>
                    </div>
                    <div class="icon-box bg-primary">
                        👤
                    </div>
                </div>
            </div>
        </div>

        <!-- RH -->
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">RH</h6>
                        <h2 class="fw-bold">@Model.TotalRH</h2>
                    </div>
                    <div class="icon-box bg-success">
                        👥
                    </div>
                </div>
            </div>
        </div>

        <!-- DIRECTEUR -->
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Directeurs</h6>
                        <h2 class="fw-bold">@Model.TotalDirecteurs</h2>
                    </div>
                    <div class="icon-box bg-warning">
                        🧑‍💼
                    </div>
                </div>
            </div>
        </div>

        <!-- OFFRES -->
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Offres</h6>
                        <h2 class="fw-bold">@Model.TotalOffres</h2>
                    </div>
                    <div class="icon-box bg-info">
                        📄
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- BIG CARDS -->
    <div class="row g-4">

        <div class="col-md-6">
            <div class="card big-card">
                <div class="card-body">
                    <h6 class="text-muted">CVs déposés</h6>
                    <h1 class="display-4 fw-bold text-primary">@Model.TotalCvs</h1>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card big-card">
                <div class="card-body">
                    <h6 class="text-muted">Matches générés</h6>
                    <h1 class="display-4 fw-bold text-success">@Model.TotalMatches</h1>
                </div>
            </div>
        </div>

    </div>

    <!-- ACTIONS -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-white fw-semibold">Actions rapides</div>
        <div class="card-body d-flex gap-3 flex-wrap">

            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary">
                👁️ Utilisateurs
            </a>

            <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-primary">
                ➕ Ajouter
            </a>

            

        </div>
    </div>

</div>