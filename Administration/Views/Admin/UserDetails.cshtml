@model Administration.Models.Utilisateur
@{
    ViewData["Title"] = "Détails utilisateur";
    string badge = Model.Role switch
    {
        "Admin"     => "bg-danger",
        "RH"        => "bg-primary",
        "Directeur" => "bg-warning text-dark",
        _           => "bg-secondary"
    };
}

<div class="container-fluid px-4 py-3">
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between">
            <h5>@Model.NomUtilisateur</h5>
            <span class="badge @badge">@Model.Role</span>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Nom utilisateur</dt>
                <dd class="col-sm-8">@Model.NomUtilisateur</dd>

                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@Model.Email</dd>

                <dt class="col-sm-4">Rôle</dt>
                <dd class="col-sm-8"><span class="badge @badge">@Model.Role</span></dd>

                @if (Model.Role == "Directeur" && !string.IsNullOrWhiteSpace(Model.Departements))
                {
                    <dt class="col-sm-4">Départements gérés</dt>
                    <dd class="col-sm-8">
                        @foreach (var dep in Model.Departements.Split(',',
                            StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <span class="badge bg-warning text-dark me-1">@dep</span>
                        }
                    </dd>
                }

                <dt class="col-sm-4">Statut</dt>
                <dd class="col-sm-8">
                    @if (Model.IsActive)
                    { <span class="badge bg-success">Actif</span> }
                    else
                    { <span class="badge bg-danger">Désactivé</span> }
                </dd>

                <dt class="col-sm-4">Date création</dt>
                <dd class="col-sm-8">@Model.DateCreation.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-4">Dernière connexion</dt>
                <dd class="col-sm-8">
                    @(Model.DateDerniereConnexion.HasValue
                        ? Model.DateDerniereConnexion.Value.ToString("dd/MM/yyyy HH:mm")
                        : "Jamais")
                </dd>
            </dl>

            <a asp-action="Users" class="btn btn-secondary btn-sm">Retour</a>
        </div>
    </div>
</div>